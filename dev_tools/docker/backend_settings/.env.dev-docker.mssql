# Development backend settings for the Docker Compose Microsoft SQL Server setup.
# Mounted into backend/.env inside the container.

TUD_DATABASE_USER=timeusediary_user
TUD_DATABASE_PASSWORD=timeusediary_Password1!
TUD_DATABASE_HOST=db
TUD_DATABASE_PORT=1433
TUD_DATABASE_NAME=timeusediary_db
TUD_DATABASE_URL=mssql+pymssql://timeusediary_user:timeusediary_Password1!@db:1433/timeusediary_db
TUD_ALLOWED_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
TUD_REPORT_DB_CONTENTS_ON_STARTUP=true
TUD_API_ADMIN_USERNAME=timeusediary_api_admin
TUD_API_ADMIN_PASSWORD=timeusediary_api_admin_password
TUD_ROOTPATH=/tud_backend
TUD_FRONTEND_URL=http://localhost:3000/report/
