# This is the example .env file for the TUD backend application.
#
# Adapt the settings as needed.
#
# The backend code loads the .env file from its current working
# directory, i.e., from where uvicorn/gunicorn was started.
#
# You can also set the env variables in your shell environment before/when running uvicorn,
# and they will take precedence over the values in this file.
#

TUD_DATABASE_USER=timeusediary_user
TUD_DATABASE_PASSWORD=timeusediary_password
TUD_DATABASE_HOST=localhost
TUD_DATABASE_PORT=5432
TUD_DATABASE_NAME=timeusediary_db
TUD_DATABASE_URL=postgresql://timeusediary_user:timeusediary_password@localhost:5432/timeusediary_db
TUD_ALLOWED_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
TUD_REPORT_DB_CONTENTS_ON_STARTUP=true  # Whether to print info about DB contents when the app starts to console. Useful in development.
# Single admin pair (backward-compatible):
TUD_API_ADMIN_USERNAME=timeusediary_api_admin
TUD_API_ADMIN_PASSWORD=timeusediary_api_admin_password
# Multiple admin pairs (optional JSON lists, same length required):
# TUD_API_ADMIN_USERNAME='["admin1", "admin2"]'
# TUD_API_ADMIN_PASSWORD='["password1", "password2"]'
# Dedicated persistent admin-audit log (separate logger output):
TUD_ADMIN_AUDIT_LOG_FILE=admin_actions.log
TUD_ADMIN_AUDIT_LOG_MAX_BYTES=5242880
TUD_ADMIN_AUDIT_LOG_BACKUP_COUNT=10
TUD_ROOTPATH=/
TUD_FRONTEND_URL=http://localhost:3000/report/
# External task HMAC secrets for callback signing, keyed by reference name.
# Each external task can optionally reference a key via "hmac_secret_reference".
# The actual secret values are stored here, never in the study config file.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# TUD_EXTERNAL_TASK_HMAC_SECRETS='{"survey_hub_v1":"a1b2c3...","payments_v2":"d4e5f6..."}'
# Test secret used by integration tests; keep in sync with the value used
# in test_external_task_hmac_callback.py.
TUD_EXTERNAL_TASK_HMAC_SECRETS='{"test_hmac_key":"integration-test-secret-do-not-use-in-production"}'

